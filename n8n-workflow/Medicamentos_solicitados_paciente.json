    {
      "parameters": {
        "jsCode": "// 1. Función de lectura segura que recorre TODAS las vueltas del ciclo (runs)\nfunction leerNodoSeguro(nombreNodo) {\n  let todosLosItems = [];\n  let runIndex = 0;\n  \n  while (true) {\n    try {\n      const items = $(nombreNodo).all(0, runIndex);\n      if (!items || items.length === 0) break;\n      todosLosItems.push(...items);\n      runIndex++;\n    } catch (e) {\n      break;\n    }\n  }\n  return todosLosItems;\n}\n\n// 2. Leemos las 3 ramas del ciclo\nconst aprobados = leerNodoSeguro(\"Edit Fields2\");\nconst parciales = leerNodoSeguro(\"Edit Fields4\");\nconst sinStock  = leerNodoSeguro(\"Edit Fields3\");\n\nconst todosProcesados = [...aprobados, ...parciales, ...sinStock];\nconst itemsAEvaluar = todosProcesados.length > 0 ? todosProcesados : $input.all();\n\nlet nombres = [];\nlet cantSolicitadas = [];\nlet cantEntregadas = [];\nlet cantPendientes = [];\n\nlet listaAprobadosApp = [];\nlet listaSinStockApp = [];\n\nlet totalSolicitado = 0;\nlet totalEntregado = 0;\nlet totalPendiente = 0;\n\nlet requiereCadenaFrio = false;\nlet hayStockAgotadoEnInventario = false;\n\nfor (const item of itemsAEvaluar) {\n  const d = item.json;\n  \n  const nombre = d.nombre_medicamento || d.nombre || \"Medicamento\";\n  const sol = parseInt(d.cantidad_solicitados || d.cantidad_solicitada || d.cantidad || 0);\n  const ent = parseInt(d.cantidad_entregado !== undefined ? d.cantidad_entregado : sol);\n  const pen = parseInt(d.cantidad_pendiente !== undefined ? d.cantidad_pendiente : (sol - ent));\n  \n  // Stock que había en bodega ANTES de este despacho\n  const stockInicial = d.stock !== undefined ? parseInt(d.stock) : 0;\n  \n  // Calculamos cuántos quedarán en bodega DESPUÉS de entregar este pedido\n  const stockRestante = stockInicial - ent;\n\n  // Si quedaron unidades pendientes O si el stock resultante en bodega es 0 o menor\n  if (pen > 0 || stockRestante <= 0) {\n    hayStockAgotadoEnInventario = true;\n  }\n\n  // Evaluamos si el medicamento requiere frío (ej. Insulina)\n  const nombreLower = nombre.toLowerCase();\n  if (\n    nombreLower.includes('insulina') || \n    d.requiere_frio === true || \n    d.cadena_frio === true || \n    d.requiere_frio === 'true'\n  ) {\n    requiereCadenaFrio = true;\n  }\n\n  nombres.push(nombre);\n  cantSolicitadas.push(sol);\n  cantEntregadas.push(ent);\n  cantPendientes.push(pen);\n\n  totalSolicitado += sol;\n  totalEntregado += ent;\n  totalPendiente += pen;\n\n  if (ent > 0) {\n    listaAprobadosApp.push({\n      nombre: nombre,\n      presentacion: d.presentacion || '',\n      cantidad: ent,\n      cantidad_entregada: ent,\n      cantidad_solicitada: sol\n    });\n  }\n\n  if (pen > 0) {\n    listaSinStockApp.push({\n      nombre: nombre,\n      presentacion: d.presentacion || '',\n      cantidad: pen,\n      cantidad_pendiente: pen,\n      cantidad_solicitada: sol\n    });\n  }\n}\n\n// 3. Estado general del pedido\nlet estadoGlobal = 'pendiente';\nif (totalPendiente > 0 && totalEntregado > 0) {\n  estadoGlobal = 'pendiente_parcial';\n} else if (totalEntregado === 0) {\n  estadoGlobal = 'esperando_reabastecimiento';\n}\n\n// 4. Mensaje explicativo\nlet mensajeFinal = \"Su turno expira en 72 horas.\";\n\nif (requiereCadenaFrio) {\n  mensajeFinal += \" ❄️ ATENCIÓN: Medicamento de cadena de frío. Recuerde traer nevera portátil o termo con hielo/gel refrigerante.\";\n}\n\nif (totalPendiente > 0 && totalEntregado > 0) {\n  mensajeFinal += ` ⚠️ ATENCIÓN: Entrega parcial por inventario. Se autorizan ${totalEntregado} de ${totalSolicitado} unidad(es). Quedan ${totalPendiente} pendiente(s) por reclamar.`;\n} else if (totalEntregado === 0) {\n  mensajeFinal = \"⏳ Todos los medicamentos solicitados están en espera de reabastecimiento.\";\n}\n\n// 5. Obtener los datos del registro original\nconst registroOriginal = $('Create a row1').first() ? $('Create a row1').first().json : {};\nconst primerItem = $input.first() ? $input.first().json : {};\n\nconst turnoReal = registroOriginal.turno || primerItem.turno || \"T-100\";\n\nreturn {\n  json: {\n    id: registroOriginal.id || primerItem.id,\n    turno: turnoReal,\n    estado: estadoGlobal,\n    alerta_stock_agotado: hayStockAgotadoEnInventario,\n    nombre_medicamento: nombres.join(\", \"),\n    cantidad_solicitados: cantSolicitadas.join(\", \"),\n    cantidad_entregado: cantEntregadas.join(\", \"),\n    cantidad_pendiente: cantPendientes.join(\", \"),\n    \n    advertencia: mensajeFinal,\n    mensaje: mensajeFinal,\n    indicaciones: mensajeFinal,\n    aprobados: listaAprobadosApp,\n    sin_stock: listaSinStockApp,\n    total_solicitado: totalSolicitado,\n    total_entregado: totalEntregado,\n    total_pendiente: totalPendiente\n  }\n};"
      },
